class VisualizationWidget(QWidget):
    def __init__(self):
        super().__init__()
        self.x_value = 512
        self.y_value = 512
        self.setMinimumSize(340, 340)

    def update_values(self, x, y):
        self.x_value = x
        self.y_value = y
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)

        rect = self.rect().adjusted(20, 20, -20, -20)

        painter.setPen(QPen(QColor("#3b4252"), 2))
        painter.setBrush(QBrush(QColor("#161b22")))
        painter.drawRoundedRect(rect, 18, 18)

        center_x = rect.center().x()
        center_y = rect.center().y()

        grid_pen = QPen(QColor("#2d3748"), 1)
        painter.setPen(grid_pen)

        for i in range(1, 4):
            x = rect.left() + i * rect.width() / 4
            y = rect.top() + i * rect.height() / 4
            painter.drawLine(int(x), int(rect.top()), int(x), int(rect.bottom()))
            painter.drawLine(int(rect.left()), int(y), int(rect.right()), int(y))

        axis_pen = QPen(QColor("#4fd1c5"), 2)
        painter.setPen(axis_pen)
        painter.drawLine(int(rect.left()), int(center_y), int(rect.right()), int(center_y))
        painter.drawLine(int(center_x), int(rect.top()), int(center_x), int(rect.bottom()))

        px = rect.left() + (self.x_value / 1023.0) * rect.width()
        py = rect.top() + (self.y_value / 1023.0) * rect.height()

        glow_color = QColor(0, 255, 200, 70)
        painter.setBrush(QBrush(glow_color))
        painter.setPen(Qt.PenStyle.NoPen)
        painter.drawEllipse(QRectF(px - 16, py - 16, 32, 32))

        painter.setBrush(QBrush(QColor("#00ffd0")))
        painter.setPen(QPen(QColor("#b2fff4"), 2))
        painter.drawEllipse(QRectF(px - 7, py - 7, 14, 14))


