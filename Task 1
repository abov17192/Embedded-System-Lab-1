#include <avr/io.h>
#include <util/delay.h>

int main(void)
{
   
    DDRB |= (1 << PB0) | (1 << PB1) | (1 << PB2);

    while (1)
    {
        
        PORTB = (1 << PB0);
        _delay_ms(350);

    
        PORTB = (1 << PB1);
        _delay_ms(1000);

       
        PORTB = (1 << PB2);
        _delay_ms(500);

        
        PORTB = 0x00;
        _delay_ms(500);
    }
}
